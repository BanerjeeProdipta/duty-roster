{
	"name": "@Duty-Roster/api",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./server": {
			"default": "./src/server.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"check-types": "tsc --noEmit",
		"test": "NODE_OPTIONS=--experimental-vm-modules jest",
		"generate-next-month": "bun run src/scripts/generate-next-month.ts"
	},
	"dependencies": {
		"@Duty-Roster/auth": "workspace:*",
		"@Duty-Roster/db": "workspace:*",
		"@Duty-Roster/env": "workspace:*",
		"@trpc/client": "catalog:",
		"@trpc/server": "catalog:",
		"@trpc/tanstack-react-query": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@Duty-Roster/config": "workspace:*",
		"@types/jest": "^30.0.0",
		"hono": "catalog:",
		"jest": "^30.4.2",
		"ts-jest": "^29.4.11",
		"typescript": "^5"
	}
}
