{
	"extends": "@Duty-Roster/config/tsconfig.base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"paths": {
			"@Duty-Roster/ui/*": ["./src/*"]
		},
		"typeRoots": ["./src/types", "./node_modules/@types"],
		"types": []
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "src/types/**/*.d.ts"],
	"exclude": ["node_modules"]
}
