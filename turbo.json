{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"globalEnv": [
		"CLOUDFLARE_API_TOKEN",
		"CLOUDFLARE_ACCOUNT_ID",
		"DATABASE_URL",
		"BETTER_AUTH_SECRET",
		"NEXT_PUBLIC_SERVER_URL",
		"BETTER_AUTH_URL",
		"CORS_ORIGIN"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**", ".cloudflare/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"build:cf": {
			"dependsOn": ["^build:cf"],
			"outputs": [".cloudflare/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"db:push": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false,
			"persistent": true
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"db:seed": {
			"cache": false
		},
		"db:seed:local": {
			"cache": false
		},
		"db:seed:prods": {
			"cache": false
		},
		"db:setup-local": {
			"cache": false
		},
		"generate-next-month": {
			"cache": false
		},
		"deploy": {
			"dependsOn": ["build"]
		}
	}
}
