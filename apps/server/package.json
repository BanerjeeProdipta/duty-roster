{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "bunx tsdown",
		"build:cf": "bunx tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs",
		"deploy": "wrangler deploy"
	},
	"dependencies": {
		"@Duty-Roster/api": "workspace:*",
		"@Duty-Roster/auth": "workspace:*",
		"@Duty-Roster/db": "workspace:*",
		"@Duty-Roster/env": "workspace:*",
		"@hono/trpc-server": "^0.4.0",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@Duty-Roster/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.16.5",
		"typescript": "^5",
		"wrangler": "^4.85.0"
	}
}
