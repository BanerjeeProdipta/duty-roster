{
	"name": "web",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "bash scripts/download-piper-assets.sh && next dev --port 3001",
		"build": "bash scripts/download-piper-assets.sh && node scripts/patch-piper-tts-web.mjs && next build",
		"start": "next start -p 3001",
		"build:cf": "bash scripts/download-piper-assets.sh && node scripts/patch-piper-tts-web.mjs && npm_config_user_agent=npm/10.0.0 npx @cloudflare/next-on-pages -o .cloudflare",
		"deploy": "bunx wrangler pages deploy .cloudflare --project-name=duty-roster",
		"postinstall": "node scripts/patch-piper-tts-web.mjs",
		"download:piper": "bash scripts/download-piper-assets.sh"
	},
	"dependencies": {
		"@Duty-Roster/api": "workspace:*",
		"@Duty-Roster/auth": "workspace:*",
		"@Duty-Roster/env": "workspace:*",
		"@Duty-Roster/ui": "workspace:*",
		"@Duty-Roster/voice-parser": "workspace:*",
		"@mintplex-labs/piper-tts-web": "^1.0.4",
		"@tanstack/react-form": "catalog:",
		"@tanstack/react-query": "catalog:",
		"@tanstack/react-virtual": "^3.13.24",
		"@trpc/client": "catalog:",
		"@trpc/server": "catalog:",
		"@trpc/tanstack-react-query": "catalog:",
		"babel-plugin-react-compiler": "^1.0.0",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"lucide-react": "catalog:",
		"next": "^15.1.0",
		"next-themes": "catalog:",
		"ogl": "^1.0.11",
		"onnxruntime-web": "^1.26.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"sonner": "catalog:",
		"zod": "catalog:",
		"zustand": "^5.0.3"
	},
	"devDependencies": {
		"@Duty-Roster/config": "workspace:*",
		"@ducanh2912/next-pwa": "^10.2.8",
		"@next/bundle-analyzer": "^16.2.5",
		"@tailwindcss/postcss": "^4.1.18",
		"@tanstack/react-query-devtools": "^5.91.1",
		"@types/node": "^20",
		"@types/react": "^19.2.10",
		"@types/react-dom": "catalog:",
		"tailwindcss": "^4.1.18",
		"typescript": "^5",
		"vercel": "^41.0.0"
	}
}
