{
	"name": "Duty-Roster",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"hono": "^4.8.2",
			"@trpc/server": "^11.13.4",
			"better-auth": "1.5.5",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"sonner": "^2.0.5",
			"@trpc/tanstack-react-query": "^11.13.4",
			"@trpc/client": "^11.13.4",
			"@tanstack/react-query": "^5.90.12",
			"@tanstack/react-form": "^1.28.0",
			"@types/react-dom": "^19.2.3",
			"@better-auth/expo": "1.5.5"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @Duty-Roster/db db:push",
		"db:studio": "turbo -F @Duty-Roster/db db:studio",
		"db:generate": "turbo -F @Duty-Roster/db db:generate",
		"db:migrate": "turbo -F @Duty-Roster/db db:migrate",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@Duty-Roster/env": "workspace:*",
		"dotenv": "catalog:",
		"react-window": "^2.2.7",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@Duty-Roster/config": "workspace:*",
		"@biomejs/biome": "^2.2.0",
		"@types/bun": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.5"
}
